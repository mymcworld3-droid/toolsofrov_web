{% extends "layout.html" %}

{% block content %}
<style>
  /* 遊戲版面容器與屬性總結區 */
  .game-board-container {
    max-width: 800px;
    margin: 40px auto;
    text-align: center;
    background-color: #1a1a1a;
    padding: 30px;
    border-radius: 10px;
    color: #e0e0e0;
    box-shadow: 0 0 15px rgba(0, 0, 0, 0.8);
  }
  
  .stats-summary {
    margin-top: 20px;
    margin-bottom: 20px;
    padding: 15px;
    background-color: #333;
    border-radius: 8px;
    font-size: 18px;
  }

  /* 確保裝備格子與選取狀態可見的樣式 */
  .equip-board {
    display: flex;
    gap: 15px;
    margin: 20px 0;
    justify-content: center;
  }
  
  .equip-slot {
    width: 64px;
    height: 64px;
    background-color: #2c2c2c;
    border: 2px dashed #888;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    position: relative;
    transition: border-color 0.2s, transform 0.2s;
  }
  
  .equip-slot:hover {
    border-color: #f1c40f;
    transform: scale(1.05);
  }
  
  .equip-slot img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 6px;
  }
  
  /* 裝備選擇庫樣式 */
  .equipment-pool {
    margin-top: 30px;
    padding: 20px;
    background-color: #222;
    border: 1px solid #444;
    border-radius: 8px;
  }
  
  .pool-items {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
    margin-bottom: 20px;
  }
  
  .pool-item {
    width: 50px;
    height: 50px;
    cursor: pointer;
    border: 2px solid transparent;
    border-radius: 5px;
    transition: border-color 0.2s;
  }
  
  /* 點擊裝備庫物品後，準備裝配時的發光效果 */
  .pool-item.selected-for-equip {
    border-color: #f1c40f;
    box-shadow: 0 0 8px #f1c40f;
  }
</style>

<div class="game-board-container">
  <h2>裝備配置與總結</h2>

  <div class="equip-board">
    <div class="equip-slot" onclick="handleSlotClick(0)"></div>
    <div class="equip-slot" onclick="handleSlotClick(1)"></div>
    <div class="equip-slot" onclick="handleSlotClick(2)"></div>
    <div class="equip-slot" onclick="handleSlotClick(3)"></div>
    <div class="equip-slot" onclick="handleSlotClick(4)"></div>
    <div class="equip-slot" onclick="handleSlotClick(5)"></div>
  </div>

  <div class="stats-summary">
    <h3>歲中總結屬性</h3>
    <p>攻擊力: <span id="total-attack">0</span> | 魔法力: <span id="total-magic">0</span> | 護甲值: <span id="total-armor">0</span> | 生命值: <span id="total-hp">0</span></p>
  </div>

  <div id="equipment-pool" class="equipment-pool">
    <h3>選擇要裝配的物品</h3>
    <p style="font-size: 14px; color: #aaa;">(先點擊下方裝備選取，再點擊上方空位裝備。點擊已有裝備的格子可將其卸下)</p>
    <div class="pool-items">
      <img src="/images/e1.png" alt="裝備1" class="pool-item" onclick="selectEquipmentFromPool(this, { name: '裝備1', attack: 10, magic: 0, armor: 5, hp: 50 })">
      <img src="/images/e2.png" alt="裝備2" class="pool-item" onclick="selectEquipmentFromPool(this, { name: '裝備2', attack: 0, magic: 20, armor: 0, hp: 30 })">
      <img src="/images/e3.png" alt="裝備3" class="pool-item" onclick="selectEquipmentFromPool(this, { name: '裝備3', attack: 15, magic: 5, armor: 10, hp: 0 })">
      <img src="/images/e4.png" alt="裝備4" class="pool-item" onclick="selectEquipmentFromPool(this, { name: '裝備4', attack: 5, magic: 5, armor: 20, hp: 100 })">
      <img src="/images/e5.png" alt="裝備5" class="pool-item" onclick="selectEquipmentFromPool(this, { name: '裝備5', attack: 25, magic: 0, armor: 0, hp: 0 })">
      <img src="/images/e6.png" alt="裝備6" class="pool-item" onclick="selectEquipmentFromPool(this, { name: '裝備6', attack: 0, magic: 30, armor: 5, hp: 20 })">
    </div>
  </div>
</div>

<script>
  // 儲存 6 格裝備的資料 (null 代表該格為空)
  let equippedSlots = [null, null, null, null, null, null];
  
  // 紀錄目前在裝備庫中點選了哪個裝備 (等待被放入格子)
  let pendingEquipData = null;
  let pendingEquipImgSrc = null;

  // 1. 點擊下方裝備庫的裝備時觸發
  function selectEquipmentFromPool(imgElement, itemData) {
    // 移除其他裝備的選取發光狀態
    document.querySelectorAll('.pool-item').forEach(function(el) {
      el.classList.remove('selected-for-equip');
    });
    
    // 標記當前選取的裝備
    imgElement.classList.add('selected-for-equip');
    
    // 暫存該裝備的圖片與數值資料，等待點擊格子
    pendingEquipImgSrc = imgElement.src;
    pendingEquipData = itemData; 
  }

  // 2. 點擊上方 6 個格子時觸發
  function handleSlotClick(slotIndex) {
    const slotsElements = document.querySelectorAll('.equip-slot');
    const targetSlot = slotsElements[slotIndex];

    if (pendingEquipData !== null) {
      // 情況 A：手上已經有選取的裝備 -> 裝配到該格子中
      targetSlot.innerHTML = '<img src="' + pendingEquipImgSrc + '" alt="已裝備">';
      equippedSlots[slotIndex] = pendingEquipData;

      // 裝配完成後，清除庫存區的選取狀態
      document.querySelectorAll('.pool-item').forEach(function(el) {
        el.classList.remove('selected-for-equip');
      });
      pendingEquipData = null;
      pendingEquipImgSrc = null;

    } else {
      // 情況 B：手上沒有選取裝備，但點擊了已有裝備的格子 -> 卸下該裝備
      if (equippedSlots[slotIndex] !== null) {
        targetSlot.innerHTML = '';
        equippedSlots[slotIndex] = null;
      }
    }

    // 每次裝配或卸下後，重新計算歲中最終總結
    calculateFinalStats();
  }

  // 3. 最終總結計算邏輯 (僅以裝備在格子上的物品來算)
  function calculateFinalStats() {
    let totalStats = {
      attack: 0,
      magic: 0,
      armor: 0,
      hp: 0
    };

    equippedSlots.forEach(function(item) {
      if (item !== null) {
        if (item.attack) totalStats.attack += item.attack;
        if (item.magic) totalStats.magic += item.magic;
        if (item.armor) totalStats.armor += item.armor;
        if (item.hp) totalStats.hp += item.hp;
      }
    });

    // 更新畫面上的總結數值
    document.getElementById('total-attack').innerText = totalStats.attack;
    document.getElementById('total-magic').innerText = totalStats.magic;
    document.getElementById('total-armor').innerText = totalStats.armor;
    document.getElementById('total-hp').innerText = totalStats.hp;
  }
</script>
{% endblock %}
