{% extends "layout.html" %}

{% block content %}
<div class="game-board-container">
  <h2>裝備配置</h2>

  <div class="equip-slots-container">
    <div class="equip-slot" data-slot="1" onclick="openEquipPool(1)">
      <span class="empty-icon">+</span>
    </div>
    <div class="equip-slot" data-slot="2" onclick="openEquipPool(2)">
      <span class="empty-icon">+</span>
    </div>
    <div class="equip-slot" data-slot="3" onclick="openEquipPool(3)">
      <span class="empty-icon">+</span>
    </div>
    <div class="equip-slot" data-slot="4" onclick="openEquipPool(4)">
      <span class="empty-icon">+</span>
    </div>
    <div class="equip-slot" data-slot="5" onclick="openEquipPool(5)">
      <span class="empty-icon">+</span>
    </div>
    <div class="equip-slot" data-slot="6" onclick="openEquipPool(6)">
      <span class="empty-icon">+</span>
    </div>
  </div>

  <div id="equipment-pool" class="equipment-pool" style="display: none;">
    <h3>選擇要裝配的物品</h3>
    <div class="pool-items">
      <img src="/images/e1.png" alt="裝備1" class="pool-item" onclick="equipItem('/images/e1.png')">
      <img src="/images/e2.png" alt="裝備2" class="pool-item" onclick="equipItem('/images/e2.png')">
      <img src="/images/e3.png" alt="裝備3" class="pool-item" onclick="equipItem('/images/e3.png')">
      <img src="/images/e4.png" alt="裝備4" class="pool-item" onclick="equipItem('/images/e4.png')">
      <img src="/images/e5.png" alt="裝備5" class="pool-item" onclick="equipItem('/images/e5.png')">
      <img src="/images/e6.png" alt="裝備6" class="pool-item" onclick="equipItem('/images/e6.png')">
    </div>
    <button class="close-btn" onclick="closeEquipPool()">關閉</button>
  </div>
</div>

<script>
  // 紀錄當前正在操作的裝備格
  let currentSelectedSlot = null;

  function openEquipPool(slotNumber) {
    currentSelectedSlot = slotNumber;
    const pool = document.getElementById('equipment-pool');
    pool.style.display = 'block';
  }

  function closeEquipPool() {
    const pool = document.getElementById('equipment-pool');
    pool.style.display = 'none';
    currentSelectedSlot = null;
  }

  function equipItem(imageSrc) {
    if (currentSelectedSlot !== null) {
      // 找到對應的裝備格
      const slotElement = document.querySelector(`.equip-slot[data-slot="${currentSelectedSlot}"]`);

      // 清空原本的內容 (例如加號)
      slotElement.innerHTML = '';

      // 建立新的圖片元素並放入格子中
      const img = document.createElement('img');
      img.src = imageSrc;
      slotElement.appendChild(img);

      // 裝備完成後自動關閉裝備庫
      closeEquipPool();
    }
  }
</script>
{% endblock %}
